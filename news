<script>
  const examples = [
    "BREAKING: Scientists CONFIRM drinking coffee cures ALL cancers – Big Pharma trying to SUPPRESS this secret!!!",
    "Federal Reserve raises interest rates by 25 basis points, citing continued concerns about inflation according to official press release.",
    "EXCLUSIVE: Secret government documents reveal moon landing was filmed in Hollywood studio by Stanley Kubrick – whistleblower exposes TRUTH",
    "NASA's Artemis program successfully completed its latest test flight, bringing crewed lunar missions closer to reality, agency officials stated."
  ];
  let history = [];
  let fakeCount = 0;
  let totalCount = 0;
  let selectedOption = 'headline';
  const textarea = document.getElementById('newsText');
  const charCount = document.getElementById('charCount');
  const analyzeBtn = document.getElementById('analyzeBtn');
  textarea.addEventListener('input', () => {
    const len = textarea.value.length;
    charCount.textContent = len;
    analyzeBtn.disabled = len < 5;
  });
  function selectOption(el) {
    document.querySelectorAll('.option-chip').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    selectedOption = el.dataset.option;
  }
  function loadExample(i) {
    textarea.value = examples[i];
    charCount.textContent = examples[i].length;
    analyzeBtn.disabled = false;
    textarea.focus();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  function scoreText(text) {
    const t = text.toLowerCase();
    let fakeScore = 0;
    const capsWords = (text.match(/\b[A-Z]{3,}\b/g) || []).length;
    fakeScore += Math.min(capsWords * 8, 30);
    const clickbait = ['breaking', 'exclusive', 'shocking', 'bombshell', 'exposed', 'secret', 'they don\'t want', 'suppressed', 'cover-up', 'confirm', 'whistleblower', 'truth', 'banned', 'censored', 'miracle'];
    clickbait.forEach(w => { if (t.includes(w)) fakeScore += 12; });
    const conspiracy = ['big pharma', 'deep state', 'new world order', 'illuminati', 'government hide', 'mainstream media', 'fake news'];
    conspiracy.forEach(w => { if (t.includes(w)) fakeScore += 18; });
    const excl = (text.match(/!/g) || []).length;
    const quest = (text.match(/\?/g) || []).length;
    fakeScore += Math.min(excl * 10 + quest * 5, 25);
    const credible = ['according to', 'official', 'researchers', 'study', 'university', 'percent', 'report', 'data', 'announced', 'stated', 'published'];
    credible.forEach(w => { if (t.includes(w)) fakeScore -= 14; });
    if (text.length < 40) fakeScore += 10;
    fakeScore = Math.max(0, Math.min(100, fakeScore));
    const jitter = (Math.random() - 0.5) * 10;
    fakeScore = Math.max(0, Math.min(100, fakeScore + jitter));
    return Math.round(fakeScore);
  }
  function getSignals(text) {
    const t = text.toLowerCase();
    const caps = Math.min((text.match(/\b[A-Z]{3,}\b/g) || []).length * 20, 100);
    const excl = Math.min((text.match(/!/g) || []).length * 25, 100);
    const clickbait = ['breaking', 'exclusive', 'shocking', 'exposed', 'secret', 'truth', 'suppressed', 'banned'];
    const cbScore = Math.min(clickbait.filter(w => t.includes(w)).length * 30, 100);
    const credWords = ['according to', 'official', 'published', 'stated', 'data', 'report', 'researchers'];
    const credScore = Math.min(credWords.filter(w => t.includes(w)).length * 25, 100);
    return [
      { name: 'Sensational Language', score: cbScore, color: cbScore > 50 ? '#ef4444' : '#10b981' },
      { name: 'Emotional Triggers',   score: excl,    color: excl > 40    ? '#ef4444' : '#10b981' },
      { name: 'ALL CAPS Usage',        score: caps,    color: caps > 40    ? '#ef4444' : '#10b981' },
      { name: 'Source Credibility',    score: credScore, color: credScore > 40 ? '#10b981' : '#f59e0b' },
    ];
  }
  function getNotes(text, isFake, confidence) {
    const t = text.toLowerCase();
    const notes = [];
    if ((text.match(/\b[A-Z]{3,}\b/g) || []).length > 1)
      notes.push('Excessive use of ALL CAPS is a common tactic to generate emotional urgency.');
    if ((text.match(/!/g) || []).length >= 2)
      notes.push('Multiple exclamation marks signal emotional manipulation over factual reporting.');
    if (['breaking', 'exclusive', 'shocking', 'bombshell'].some(w => t.includes(w)))
      notes.push('Clickbait trigger words ("BREAKING", "EXCLUSIVE") are frequently used in misinformation.');
    if (['big pharma', 'deep state', 'cover-up', 'suppressed', 'they don\'t want'].some(w => t.includes(w)))
      notes.push('Conspiracy framing detected — appeals to hidden forces without verifiable evidence.');
    if (['according to', 'official', 'published', 'stated'].some(w => t.includes(w)))
      notes.push('Attributable sourcing language detected, which is a positive credibility signal.');
    if (['university', 'study', 'researchers', 'data'].some(w => t.includes(w)))
      notes.push('Scientific or academic framing is present, suggesting more credible sourcing.');
    if (notes.length === 0)
      notes.push(isFake
        ? 'The text exhibits patterns consistent with low-credibility or misleading content.'
        : 'The text exhibits patterns consistent with credible, factual reporting style.'
      );
    return notes.slice(0, 4);
  }
  async function analyze() {
    const text = textarea.value.trim();
    if (!text) return;
    analyzeBtn.disabled = true;
    document.getElementById('resultCard').classList.remove('show');
    const progressWrap = document.getElementById('progressWrap');
    const progressFill = document.getElementById('progressFill');
    const progressLabel = document.getElementById('progressLabel');
    progressWrap.classList.add('show');
    const steps = [
      [15, 'Parsing linguistic patterns…'],
      [35, 'Evaluating emotional triggers…'],
      [55, 'Cross-referencing credibility signals…'],
      [75, 'Analyzing source attribution…'],
      [90, 'Computing confidence score…'],
      [100, 'Analysis complete.'],
    ];
    for (const [pct, label] of steps) {
      progressFill.style.width = pct + '%';
      progressLabel.textContent = label;
      await new Promise(r => setTimeout(r, 280 + Math.random() * 200));
    }
    await new Promise(r => setTimeout(r, 300));
    progressWrap.classList.remove('show');
    progressFill.style.width = '0%';
    analyzeBtn.disabled = false;
    const fakeScore = scoreText(text);
    const isFake = fakeScore >= 60;
    const isUnsure = fakeScore >= 35 && fakeScore < 60;
    const verdict = isFake ? 'fake' : isUnsure ? 'unsure' : 'real';
    const confidence = isFake ? fakeScore : isUnsure ? Math.round(50 + Math.random() * 10) : 100 - fakeScore;
    const resultCard = document.getElementById('resultCard');
    resultCard.className = 'result-card show ' + verdict;
    const verdictData = {
      fake:   { icon: '🚫', label: 'Likely Fake News', sub: 'High probability of misinformation' },
      real:   { icon: '✅', label: 'Likely Credible',  sub: 'Consistent with factual reporting' },
      unsure: { icon: '⚠️', label: 'Uncertain',        sub: 'Insufficient signals — verify independently' },
    }[verdict];
    document.getElementById('verdictIcon').textContent = verdictData.icon;
    document.getElementById('verdictLabel').textContent = verdictData.label;
    document.getElementById('verdictSub').textContent = verdictData.sub;
    const confEl = document.getElementById('confidenceVal');
    confEl.textContent = '0%';
    let cur = 0;
    const target = confidence;
    const step = Math.ceil(target / 30);
    const timer = setInterval(() => {
      cur = Math.min(cur + step, target);
      confEl.textContent = cur + '%';
      if (cur >= target) clearInterval(timer);
    }, 30);
    setTimeout(() => {
      document.getElementById('gaugeFill').style.width = confidence + '%';
    }, 100);
    const signals = getSignals(text);
    const signalsGrid = document.getElementById('signalsGrid');
    signalsGrid.innerHTML = signals.map(s => `
      <div class="signal-item">
        <div class="signal-name">${s.name}</div>
        <div class="signal-bar-wrap">
          <div class="signal-bar" style="background:${s.color}; width:0%" data-target="${s.score}"></div>
        </div>
        <div class="signal-score">${s.score}%</div>
      </div>
    `).join('');
    setTimeout(() => {
      signalsGrid.querySelectorAll('.signal-bar').forEach(bar => {
        bar.style.width = bar.dataset.target + '%';
      });
    }, 150);
    const notes = getNotes(text, isFake, confidence);
    document.getElementById('noteList').innerHTML = notes.map(n => `<li>${n}</li>`).join('');
    resultCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
    totalCount++;
    if (verdict === 'fake') fakeCount++;
    document.getElementById('stat-analyzed').textContent = totalCount;
    document.getElementById('stat-fake').textContent = Math.round((fakeCount / totalCount) * 100) + '%';
    history.unshift({ text, verdict, confidence });
    if (history.length > 5) history.pop();
    renderHistory();
  }
  function renderHistory() {
    const el = document.getElementById('historyList');
    if (!history.length) {
      el.innerHTML = '<div class="empty-history">No analyses yet.</div>';
      return;
    }
    el.innerHTML = history.map((h, i) => `
      <div class="history-item" onclick="loadHistoryItem(${i})">
        <div class="history-dot ${h.verdict}"></div>
        <div class="history-text">${h.text}</div>
        <div class="history-conf ${h.verdict}">${h.confidence}%</div>
      </div>
    `).join('');
  }
  function loadHistoryItem(i) {
    textarea.value = history[i].text;
    charCount.textContent = history[i].text.length;
    analyzeBtn.disabled = false;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
</body>
</html>
